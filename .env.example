# ──────────────────────────────────────────────
# DPDP Consent Management Platform — Environment
# ──────────────────────────────────────────────
#
# Architecture:
#   Frontend (Next.js)  → Vercel
#   Backend  (FastAPI)  → VPS
#
# Copy this to .env and fill in your values.

# ── Stack ─────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=change-me-to-a-cryptographically-random-64-char-string
LOG_LEVEL=info
LOG_FORMAT=json

# ── Database (Postgres) ───────────────────────
DATABASE_URL=postgresql+psycopg2://user:password@your-vps:5432/cmp
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ── Redis (optional, for rate limiting) ───────
REDIS_URL=redis://localhost:6379/0

# ── Encryption (AES-256-GCM) ──────────────────
ENCRYPTION_KEY=change-me-to-a-32-byte-base64-key

# ── JWT ───────────────────────────────────────
JWT_SECRET=change-me-to-another-64-char-random-string
JWT_ALGORITHM=HS256
SDK_TOKEN_TTL_MINUTES=15
API_TOKEN_TTL_MINUTES=60
REFRESH_TOKEN_TTL_DAYS=30

# ── Admin Console ─────────────────────────────
ADMIN_EMAIL=admin@cmp.local
ADMIN_PASSWORD=change-me-to-a-strong-password

# ── AWS (ap-south-1 — Mumbai) ────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=cmp-audit-logs
SES_SOURCE_EMAIL=noreply@cmp.example.com
SNS_SENDER_ID=CMP

# ── Webhook ──────────────────────────────────
WEBHOOK_RETRY_MAX=5
WEBHOOK_RETRY_BACKOFF_BASE=60

# ── SLA defaults (seconds) ──────────────────
SLA_RIGHTS_REQUEST=7776000      # 90 days
SLA_GRIEVANCE=259200            # 3 days

# ── Rate limiting ───────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ── CORS ────────────────────────────────────
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ── Frontend (Next.js) ──────────────────────
NEXT_PUBLIC_API_URL=https://your-vps:8000/api/v1
