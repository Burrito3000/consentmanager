{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "cd frontend && npx next build",
  "outputDirectory": "frontend/.next",
  "installCommand": "cd frontend && npm install",
  "ignoreCommand": "npx turbo-ignore",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
